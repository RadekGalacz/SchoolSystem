@model IEnumerable<AppUser>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">👥 Users</h2>
        <a asp-action="Create" class="btn btn-success">➕ Create User</a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle shadow-sm">
                <thead class="table-light">
                    <tr>
                        
                        <th>Name</th>
                        <th>Email</th>
                        <th>ID</th>
                        <th style="width: 100px;">Update</th>
                        <th style="width: 100px;">Delete</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (AppUser user in Model)
                    {
                        <tr>
                            <td>@user.UserName</td>
                            <td>@user.Email</td>
                            <td>@user.Id</td>
                            <td>
                                <a class="btn btn-sm btn-warning w-100" asp-action="Edit" asp-route-id="@user.Id">Edit</a>
                            </td>
                            <td>
                            <a asp-action="GetToDelete" asp-route-id="@user.Id" class="btn btn-sm btn-danger w-100">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No users found.</div>
    }
</div>